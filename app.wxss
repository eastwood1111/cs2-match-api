page {
  min-height: 100vh;
  background: #f5f6f8;
  color: #17191c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.primary-btn,
.secondary-btn,
.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-btn {
  color: #ffffff;
  background: #16895d;
}

.secondary-btn {
  color: #17191c;
  background: #ffffff;
  border: 1rpx solid #d9dde3;
}

.icon-btn {
  width: 88rpx;
  color: #ffffff;
  background: #17191c;
}
